# REQUIRED: shared beta backend
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_PRIVATE_SERVICE_ROLE_KEY

# REQUIRED: encrypts approval-room tokens and owner codes at rest
RECEIPTS_ENCRYPTION_SECRET=replace-with-at-least-32-random-characters

# OPTIONAL: easiest single-owner beta connection
# Keep this in Netlify environment variables. Never commit the real key.
BUFFER_API_KEY=

# OPTIONAL: target a specific organization when the Buffer account has several
BUFFER_ORGANIZATION_ID=

# OPTIONAL: email invitations and approval confirmations
RESEND_API_KEY=
RESEND_FROM=Receipts <approvals@yourdomain.com>

# REQUIRED for production links in invitation emails
APP_BASE_URL=https://your-site.netlify.app
